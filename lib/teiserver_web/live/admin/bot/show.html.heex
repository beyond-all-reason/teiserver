<.header>
  Bot: {@bot.name}
  <:actions>
    <.link patch={~p"/teiserver/admin/bot/#{@bot.id}/edit"} phx-click={JS.push_focus()}>
      <.button>Edit</.button>
    </.link>
    <.button phx-click="confirm_delete" class="btn-danger">
      Delete bot
    </.button>
  </:actions>
</.header>

<.modal
  :if={@confirm_delete}
  id="confirm-delete-modal"
  show
  on_cancel={JS.push("cancel_delete")}
  on_confirm={JS.push("delete_bot")}
>
  <:title>Delete bot {@bot.name}?</:title>
  <:subtitle>This action cannot be undone. All credentials will also be deleted.</:subtitle>
  <:confirm>Yes, delete</:confirm>
  <:cancel>Cancel</:cancel>
</.modal>

<div :if={@client_secret} class="alert alert-danger">
  Secret only shown once! <pre>{@client_secret}</pre>
</div>

<h2>Credentials</h2>

<%= if @credentials == [] do %>
  <p>No credentials.</p>
<% else %>
  <.table id="credentials" rows={@credentials}>
    <:col :let={cred} label="Created at">{cred.inserted_at}</:col>
    <:col :let={cred} label="Application">{cred.application.name}</:col>
    <:col :let={cred} label="Client ID"><pre>{cred.client_id}</pre></:col>
    <:col :let={cred} label="Scopes">{Enum.join(cred.application.scopes, ", ")}</:col>
    <:action :let={cred}>
      <.link
        phx-click={JS.push("confirm_delete_credential", value: %{cred_id: cred.id})}
        class="btn btn-danger btn-sm"
      >
        Delete
      </.link>
    </:action>
  </.table>
<% end %>

<.modal
  :if={@credential_to_delete}
  id="confirm-delete-credential-modal"
  show
  on_cancel={JS.push("cancel_delete_credential")}
  on_confirm={JS.push("delete_credential")}
>
  <:title>Delete credential?</:title>
  <:subtitle>This credential will be permanently removed.</:subtitle>
  <:confirm>Yes, delete</:confirm>
  <:cancel>Cancel</:cancel>
</.modal>

<h2>Create credential</h2>
<form phx-submit="create_credential">
  <.input
    type="select"
    name="application"
    label="Application"
    options={Enum.map(@applications, &{&1.name, &1.id})}
    value=""
  />
  <.button type="submit" class="btn-primary">Create</.button>
</form>

<.modal
  :if={@live_action == :edit}
  id="bot-edit-modal"
  show
  on_cancel={JS.patch(~p"/teiserver/admin/bot/#{@bot.id}")}
>
  <.live_component
    module={FormComponent}
    id={@bot.id}
    title={@page_title}
    action={@live_action}
    bot={@bot}
    patch={~p"/teiserver/admin/bot/#{@bot.id}"}
  />
</.modal>
