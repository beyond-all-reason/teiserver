<% bsname = view_colour() %>
<div class="row section-menu">
  <div class="col-md-12">
    <div class={"card border-#{bsname}"}>
      <div class="card-body">
        {UserHTML.section_menu(
          Map.merge(assigns, %{
            active: "new"
          })
        )}

        <hr />

        {UserHTML.user_form.(Map.put(assigns, :action, ~p"/teiserver/admin/user"))}
      </div>
    </div>
  </div>
</div>
