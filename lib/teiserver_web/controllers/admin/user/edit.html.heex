<% bsname = view_colour() %>
<div class="row">
  <div class="col-md-12">
    <div class={"card border-#{bsname}"}>
      <div class="card-body">
        {UserHTML.section_menu(
          Map.merge(assigns, %{
            quick_search: "",
            show_search: false,
            active: "edit"
          })
        )}

        <hr />

        {UserHTML.user_form(Map.put(assigns, :action, ~p"/teiserver/admin/user/#{@user}"))}
      </div>
    </div>
  </div>
</div>
